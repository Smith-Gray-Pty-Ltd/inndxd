# Inndxd — Environment Configuration
# Copy this to .env and adjust values before starting

INNDXD_DATABASE_URL=postgresql+asyncpg://inndxd:inndxd@localhost:5432/inndxd
INNDXD_OLLAMA_BASE_URL=http://localhost:11434/v1
INNDXD_OLLAMA_MODEL=deepseek-r1:latest
INNDXD_REDIS_URL=redis://localhost:6379/0
INNDXD_LOG_LEVEL=INFO